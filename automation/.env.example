# Path to your Firebase service account JSON key
# Generate at: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Your PVD 311 portal login credentials
# Create an account at: https://311.providenceri.gov/SignIn
PORTAL_EMAIL=your-email@example.com
PORTAL_PASSWORD=your-password

# Optional: run browser headless (default: false for local use)
HEADLESS=false

# Optional: dashboard port (default: 3311)
PORT=3311
