rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Anyone can create a report (PWA is unauthenticated)
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll([
                      'timestamp', 'category', 'address', 'status'
                    ])
                    && request.resource.data.category in ['unshoveled_sidewalk', 'missed_plowing']
                    && request.resource.data.address is string
                    && request.resource.data.address.size() > 0
                    && request.resource.data.address.size() < 500
                    && (request.resource.data.photo == null || (request.resource.data.photo is string && request.resource.data.photo.size() < 1024))
                    && (request.resource.data.description == null || (request.resource.data.description is string && request.resource.data.description.size() < 2000))
                    && request.resource.data.keys().size() <= 13;

      // No client reads/updates/deletes — automation uses Admin SDK
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
